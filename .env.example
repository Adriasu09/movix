# ─── TMDB (datos públicos de películas) ──────────────────────────
# Token v4 "API Read Access Token" (NO la API Key v3).
# Se obtiene en https://www.themoviedb.org/settings/api
VITE_TMDB_TOKEN=tu_tmdb_read_access_token_v4
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
VITE_TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ─── Clerk (auth · se rellena en D5) ─────────────────────────────
VITE_CLERK_PUBLISHABLE_KEY=tu_clerk_publishable_key

# ─── Supabase (datos personales: favoritos + ratings · D6) ───────
VITE_SUPABASE_URL=tu_supabase_project_url
VITE_SUPABASE_ANON_KEY=tu_supabase_anon_key
